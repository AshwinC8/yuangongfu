      "type": "text",
      "x": 60,
      "y": 1580,
      "width": 957.5999999999999,
      "height": 26.25,
      "text": "5 · Optimization 1 — the browser charges per VALUE CHANGE, not per animation",
      "originalText": "5 · Optimization 1 — the browser charges per VALUE CHANGE, not per animation",
      "fontSize": 21,
      "fontFamily": 1,
      "textAlign": "left",
