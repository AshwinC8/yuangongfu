      "type": "text",
      "x": 60,
      "y": 1500,
      "width": 826.8,
      "height": 16.25,
      "text": "But: 6 strips × ~20 rows × dozens of spans ≈ thousands of spans, each paying Layout + Paint while visible.",
      "originalText": "But: 6 strips × ~20 rows × dozens of spans ≈ thousands of spans, each paying Layout + Paint while visible.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "lineHeight": 1.25,
      "containerId": null
    },
    {
