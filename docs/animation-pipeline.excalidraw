      "x": 60,
      "y": 1470,
      "width": 811.1999999999999,
      "height": 16.25,
      "text": "Every span runs the SAME animation — the traveling wave is just different start times (animation-delay).",
      "originalText": "Every span runs the SAME animation — the traveling wave is just different start times (animation-delay).",
      "fontSize": 13,
      "fontFamily": 1,
